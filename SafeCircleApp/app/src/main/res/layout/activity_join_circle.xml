<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".JoinCircleActivity"
    android:background="@color/MainAppColour">

    <ImageButton
        android:id="@+id/imgbtnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:srcCompat="@drawable/ic_arrow_back_24"
        android:backgroundTint="@color/MainAppColour"/>

    <androidx.cardview.widget.CardView
        android:layout_width="330dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardElevation="8dp">

        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textAlignment="center"
            android:layout_gravity="center_horizontal"
            android:text="@string/enter_a_circle_code_below"
            android:textStyle="bold" />

        <com.goodiebag.pinview.Pinview
            android:id="@+id/pinview"
            android:layout_width="335dp"
            android:layout_height="80dp"
            android:layout_marginTop="50dp"
            app:pinLength="6"
            android:layout_gravity="center_horizontal"
            app:cursorVisible="true"
            app:forceKeyboard="true"
            app:inputType="number" />

        <Button
            android:id="@+id/btnJoinCircle"
            android:layout_width="300dp"
            android:layout_gravity="center_horizontal"
            android:layout_height="wrap_content"
            android:layout_marginTop="140dp"
            android:onClick="JoinCircleButton"
            android:text="@string/join_circle"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/MainAppColour" />

    </androidx.cardview.widget.CardView>

</RelativeLayout>
