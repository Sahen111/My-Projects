@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ════════════════════════════════════════════════════════
     HERO SECTION
════════════════════════════════════════════════════════ -->
<section class="hero">

    <!-- Animated background blobs -->
    <div class="hero-bg-shapes">
        <div class="hero-blob blob-1"></div>
        <div class="hero-blob blob-2"></div>
        <div class="hero-blob blob-3"></div>
        <div class="hero-blob blob-4"></div>
    </div>

    <div class="hero-content">
        <!-- Left — Text -->
        <div class="hero-text">
            <p class="hero-eyebrow">✦ Premium Event Decor · Durban & Beyond</p>

            <h1 class="hero-title">
                Where Every<br>
                <span class="accent">Detail Blooms</span>
                Into Magic
            </h1>

            <p class="hero-desc">
                From intimate baby showers to grand weddings, we craft stunning,
                bespoke decor experiences that leave your guests breathless and your
                memories timeless.
            </p>

            <div class="hero-buttons">
                <a href="#services" class="btn-primary">
                    <span>✦ Explore Services</span>
                </a>
                <a href="#contact" class="btn-outline">
                    Book a Consultation →
                </a>
            </div>
        </div>

        <!-- Right — Stacked image cards -->
        <div class="hero-visual">
            <div class="hero-cards-stack">

                <!-- Placeholder image cards using emoji-filled divs (replace src with real images) -->
                <div class="hero-card hero-card-1">
                    <div style="width:100%;height:100%;background:linear-gradient(135deg,#F4A7B5,#E8607A);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;">
                        <span style="font-size:4rem;">💐</span>
                        <span style="font-family:'Josefin Sans',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.15em;color:white;text-transform:uppercase;">Floral Setups</span>
                    </div>
                </div>

                <div class="hero-card hero-card-2">
                    <div style="width:100%;height:100%;background:linear-gradient(135deg,#D4A843,#9B72CF);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;">
                        <span style="font-size:3.5rem;">🎀</span>
                        <span style="font-family:'Josefin Sans',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.15em;color:white;text-transform:uppercase;">Baby Showers</span>
                    </div>
                </div>

                <div class="hero-card hero-card-3">
                    <div style="width:100%;height:100%;background:linear-gradient(135deg,#2ABFBF,#6B3FA0);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;">
                        <span style="font-size:3rem;">🎊</span>
                        <span style="font-family:'Josefin Sans',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.15em;color:white;text-transform:uppercase;">Celebrations</span>
                    </div>
                </div>

                <!-- Floating badge — top right -->
                <div class="hero-badge badge-top">
                    <span class="badge-icon">⭐</span>
                    <div>
                        <div class="badge-num">5.0</div>
                        <div class="badge-text">Rating</div>
                    </div>
                </div>

                <!-- Floating badge — bottom right -->
                <div class="hero-badge badge-bottom">
                    <span class="badge-icon">🎉</span>
                    <div>
                        <div class="badge-num">200+</div>
                        <div class="badge-text">Events Done</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" onclick="document.getElementById('services').scrollIntoView({behavior:'smooth'})">
        <div class="scroll-mouse"><div class="scroll-wheel"></div></div>
        <span class="scroll-text">Scroll</span>
    </div>
</section>


<!-- ════════════════════════════════════════════════════════
     SERVICES SECTION
════════════════════════════════════════════════════════ -->
<section class="services" id="services">
    <div class="services-header reveal">
        <p class="section-label">✦ What We Do</p>
        <h2 class="section-title">Decor for Every<br><em style="font-style:italic;color:var(--rose)">Beautiful Occasion</em></h2>
        <p class="section-subtitle">
            We bring your vision to life with breathtaking setups, premium materials,
            and a passion for perfection at every single event.
        </p>
    </div>

    <!-- SERVICE CARDS WRAPPER -->
    <div class="services-scene">

        <!-- Cards Grid (front panel) -->
        <div class="services-grid" id="servicesGrid">

            <div class="service-card card-baby reveal reveal-delay-1" data-service="baby">
                <span class="service-tag">Most Popular</span>
                <div class="service-icon">🍼</div>
                <h3 class="service-title">Baby Showers</h3>
                <p class="service-desc">
                    Dreamy, tender setups to celebrate the little one on the way.
                    Soft palettes, flower walls, balloon arches, and personalized touches
                    that make every mama feel cherished.
                </p>
                <div class="service-arrow">→</div>
            </div>

            <div class="service-card card-bridal reveal reveal-delay-2" data-service="bridal">
                <div class="service-icon">👰</div>
                <h3 class="service-title">Bridal Showers</h3>
                <p class="service-desc">
                    Elegant, luxurious spaces for the bride-to-be. Floral centrepieces,
                    styled tables, shimmer backdrops and golden accents for a celebration
                    as beautiful as she is.
                </p>
                <div class="service-arrow">→</div>
            </div>

            <div class="service-card card-bday reveal reveal-delay-3" data-service="birthday">
                <span class="service-tag">✨ Trending</span>
                <div class="service-icon">🎂</div>
                <h3 class="service-title">Birthday Parties</h3>
                <p class="service-desc">
                    From sweet 16s to milestone 50ths — bold, joyful decor that turns
                    any venue into a party paradise. Custom themes, balloon sculptures,
                    and vibrant colour palettes.
                </p>
                <div class="service-arrow">→</div>
            </div>

            <div class="service-card card-wedding reveal reveal-delay-4" data-service="wedding">
                <div class="service-icon">💍</div>
                <h3 class="service-title">Weddings</h3>
                <p class="service-desc">
                    Your love story deserves a stunning stage. Ceremony arches, reception
                    table styling, aisle decor, and breathtaking entrance setups crafted
                    with extraordinary attention to detail.
                </p>
                <div class="service-arrow">→</div>
            </div>

            <div class="service-card card-balloon reveal reveal-delay-2" data-service="balloon">
                <div class="service-icon">🎈</div>
                <h3 class="service-title">Balloon Artistry</h3>
                <p class="service-desc">
                    Organic balloon garlands, large number balloons, custom balloon bouquets
                    and grand entrance arches. Our balloon art adds that WOW factor to
                    any occasion.
                </p>
                <div class="service-arrow">→</div>
            </div>

            <div class="service-card card-table reveal reveal-delay-3" data-service="table">
                <div class="service-icon">🕯️</div>
                <h3 class="service-title">Table Setups</h3>
                <p class="service-desc">
                    Full table styling — charger plates, linen, centrepieces, candles,
                    menus, and bespoke place settings. Every table tells a story of
                    elegance and care.
                </p>
                <div class="service-arrow">→</div>
            </div>

        </div>

        <!-- ── GALLERY PANEL (slides in from right) ── -->
        <div class="gallery-panel" id="galleryPanel">

            <div class="gallery-panel-header">
                <button class="gallery-back-btn" id="galleryBackBtn">
                    <span class="back-arrow">←</span>
                    <span>Back to Services</span>
                </button>
                <div class="gallery-panel-title">
                    <span class="gallery-panel-icon" id="galleryPanelIcon"></span>
                    <h3 id="galleryPanelTitle"></h3>
                </div>
                <p id="galleryPanelDesc" class="gallery-panel-desc"></p>
            </div>

            <div class="gallery-panel-label">
                <span class="section-label">✦ Our Work</span>
            </div>

            <div class="gallery-grid" id="galleryGrid">
                <!-- injected by JS -->
            </div>

            <div class="gallery-panel-cta">
                <a href="#contact" class="btn-primary" onclick="closeGallery()">
                    <span>✦ Book This Service</span>
                </a>
            </div>

        </div>
    </div>
</section>


<!-- ════════════════════════════════════════════════════════
     GALLERY MARQUEE STRIP
════════════════════════════════════════════════════════ -->
<section class="gallery-strip" id="gallery">
    <div class="marquee-track">
        <!-- Replace these with real <img> tags once gallery images are added -->
        @{
            var galleryEmojis = new[] {
                ("💐","#FF9FB5,#E8607A","Florals"),
                ("🎀","#D4A843,#F0D080","Baby Shower"),
                ("🕯️","#9B72CF,#6B3FA0","Table Setup"),
                ("🎈","#2ABFBF,#7FDFCC","Balloons"),
                ("💍","#E8607A,#9B72CF","Wedding"),
                ("🎂","#D4A843,#E8607A","Birthday"),
                ("🌸","#F4A7B5,#9B72CF","Bridal"),
                ("✨","#2ABFBF,#D4A843","Entrance"),
                ("💐","#E8607A,#F4A7B5","Centrepiece"),
                ("🎊","#9B72CF,#2ABFBF","Celebration")
                };
            var doubled = galleryEmojis.Concat(galleryEmojis).ToList();
        }

        @foreach (var item in doubled)
        {
            <div class="marquee-item">
                <div class="marquee-placeholder"
                     style="background:linear-gradient(135deg,#@(item.Item2.Replace(",", "55,#"))55);flex-direction:column;gap:.5rem;">
                    <span>@item.Item1</span>
                    <span style="font-family:'Josefin Sans',sans-serif;font-size:.6rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.8)">@item.Item3</span>
                </div>
            </div>
        }
    </div>
</section>


<!-- ════════════════════════════════════════════════════════
     ABOUT / BRAND STRIP
════════════════════════════════════════════════════════ -->
<section class="about-strip" id="about">
    <div class="about-grid">

        <!-- Left — Text -->
        <div class="about-text">
            <p class="section-label reveal">✦ Our Story</p>
            <h2 class="section-title reveal reveal-delay-1">
                Beauty Lives in<br><em>Every Detail</em>
            </h2>

            <p class="reveal reveal-delay-2">
                Bloom &amp; Co. was born from a deep love of beautiful spaces and the
                belief that every celebration deserves to feel extraordinary. We are
                a passionate team of decor artists dedicated to creating environments
                that take your breath away.
            </p>
            <p class="reveal reveal-delay-3">
                From the moment you enquire, to the last guest leaving the venue, we are
                with you every step of the way — ensuring your vision is brought to life
                with precision, creativity and heart.
            </p>

            <div class="about-stats">
                <div class="stat-item reveal reveal-delay-1">
                    <div class="stat-num" data-val="200" data-suffix="+">0+</div>
                    <div class="stat-label">Events Styled</div>
                </div>
                <div class="stat-item reveal reveal-delay-2">
                    <div class="stat-num" data-val="5" data-suffix="★">0★</div>
                    <div class="stat-label">Average Rating</div>
                </div>
                <div class="stat-item reveal reveal-delay-3">
                    <div class="stat-num" data-val="4" data-suffix=" yrs">0 yrs</div>
                    <div class="stat-label">Experience</div>
                </div>
            </div>
        </div>

        <!-- Right — Visual collage -->
        <div class="about-visuals reveal reveal-delay-2">
            <div class="av-img av-img-1">
                <div style="width:100%;height:100%;background:linear-gradient(135deg,#E8607A,#D4A843);display:flex;align-items:center;justify-content:center;font-size:5rem;">🌸</div>
            </div>
            <div class="av-img av-img-2">
                <div style="width:100%;height:100%;background:linear-gradient(135deg,#9B72CF,#2ABFBF);display:flex;align-items:center;justify-content:center;font-size:4rem;">💐</div>
            </div>
            <div class="av-img av-img-3">
                <div style="width:100%;height:100%;background:linear-gradient(135deg,#2ABFBF,#E8607A);display:flex;align-items:center;justify-content:center;font-size:3.5rem;">🕯️</div>
            </div>
            <div class="av-badge">
                <div class="av-badge-inner">
                    Quality<br>Guaranteed
                </div>
            </div>
        </div>

    </div>
</section>


<!-- ════════════════════════════════════════════════════════
     TESTIMONIALS
════════════════════════════════════════════════════════ -->
<section class="testimonials" id="testimonials">
    <div class="testimonials-header reveal">
        <p class="section-label">✦ Client Love</p>
        <h2 class="section-title">Words From Our<br><em style="color:var(--lavender);font-style:italic">Happy Clients</em></h2>
    </div>

    <div class="testimonials-track">

        <div class="testi-card reveal reveal-delay-1">
            <div class="testi-stars">★★★★★</div>
            <p class="testi-text">
                "The baby shower decor was absolutely beyond anything I imagined.
                Every single detail was perfect — it looked like a magazine shoot!
                My guests couldn't stop talking about it."
            </p>
            <div class="testi-author">
                <div class="testi-avatar">TM</div>
                <div>
                    <div class="testi-name">Thandi M.</div>
                    <div class="testi-event">Baby Shower · March 2024</div>
                </div>
            </div>
        </div>

        <div class="testi-card reveal reveal-delay-2">
            <div class="testi-stars">★★★★★</div>
            <p class="testi-text">
                "Bloom &amp; Co. turned my wedding reception into something from a
