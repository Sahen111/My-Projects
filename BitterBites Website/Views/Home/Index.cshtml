@{
    ViewData["Title"] = "Home";
}

<!-- ═══════════════════════════════════════════
     HERO SECTION
════════════════════════════════════════════ -->
<section class="hero" id="home" aria-label="Hero">
    <!-- Background Circles -->
    <div class="hero-bg-circles" aria-hidden="true">
        <div class="hero-circle"></div>
        <div class="hero-circle"></div>
        <div class="hero-circle"></div>
    </div>

    <div class="hero-inner">
        <!-- Content -->
        <div class="hero-content">
            <span class="hero-badge">✨ Handcrafted with Love</span>

            <h1 class="hero-title">
                Sweet Treats
                <em>for Every Moment</em>
            </h1>

            <p class="hero-subtitle">
                Beautifully crafted cupcakes, cakes, brownies and treat boxes — baked fresh to order and made to delight. Every bite tells a story.
            </p>

            <div class="hero-cta">
                <a href="#products" class="btn btn-primary">
                    🧁 Browse Our Menu
                </a>
                <button class="btn btn-outline" id="heroOrderBtn">
                    💌 Place an Order
                </button>
            </div>

            <div class="hero-stats">
                <div>
                    <div class="hero-stat-num">100%</div>
                    <div class="hero-stat-label">Made Fresh</div>
                </div>
                <div>
                    <div class="hero-stat-num">7+</div>
                    <div class="hero-stat-label">Product Ranges</div>
                </div>
                <div>
                    <div class="hero-stat-num">24hr</div>
                    <div class="hero-stat-label">Response Time</div>
                </div>
            </div>
        </div>

        <!-- Visual -->
        <div class="hero-visual" aria-hidden="true">
            <div class="hero-img-wrap">
                <img src="https://images.unsplash.com/photo-1614707267537-b85aaf00c4b7?w=700&q=85"
                     alt="Beautiful cupcake bouquet"
                     class="hero-img-main" />

                <!-- Floating cards -->
                <div class="hero-float-card">
                    <span class="float-card-icon">🎂</span>
                    <div class="float-card-text">
                        <strong>Mini Cakes</strong>
                        <span>from R220</span>
                    </div>
                </div>

                <div class="hero-float-card">
                    <span class="float-card-icon">🍫</span>
                    <div class="float-card-text">
                        <strong>Brownies</strong>
                        <span>from R100</span>
                    </div>
                </div>

                <div class="hero-float-card">
                    <span class="float-card-icon">⭐</span>
                    <div class="float-card-text">
                        <strong>Custom Orders</strong>
                        <span>Available!</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════
     FEATURES / WHY US
════════════════════════════════════════════ -->
<section class="section features-section" id="about" aria-label="Our promise">
    <div class="section-inner">
        <div class="section-header reveal">
            <span class="section-eyebrow">Why Bitter Bites?</span>
            <h2 class="section-title">Baked with <em>Passion</em></h2>
            <p class="section-subtitle">Everything we make is crafted fresh to order, with quality ingredients and a whole lot of heart.</p>
        </div>

        <div class="features-grid">
            <div class="feature-card reveal reveal-delay-1">
                <span class="feature-icon" aria-hidden="true">🌸</span>
                <h3 class="feature-title">Fresh to Order</h3>
                <p class="feature-desc">Every treat is baked fresh when you order — never sitting on a shelf. Just pure, made-to-order goodness.</p>
            </div>

            <div class="feature-card reveal reveal-delay-2">
                <span class="feature-icon" aria-hidden="true">🎨</span>
                <h3 class="feature-title">Custom Designs</h3>
                <p class="feature-desc">From colours and themes to personalised messages — we bring your vision to life in every sweet detail.</p>
            </div>

            <div class="feature-card reveal reveal-delay-3">
                <span class="feature-icon" aria-hidden="true">💖</span>
                <h3 class="feature-title">Made with Love</h3>
                <p class="feature-desc">Every batch is made with care, attention, and genuine passion for creating something truly special for you.</p>
            </div>

            <div class="feature-card reveal reveal-delay-4">
                <span class="feature-icon" aria-hidden="true">🎁</span>
                <h3 class="feature-title">Perfect Gifting</h3>
                <p class="feature-desc">Beautifully boxed and ready to gift. Whether it's a birthday, anniversary, or just because — we've got you covered.</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════
     PRODUCTS SECTION
════════════════════════════════════════════ -->
<section class="section products-section" id="products" aria-label="Our products">
    <div class="section-inner">
        <div class="section-header reveal">
            <span class="section-eyebrow">Our Sweet Menu</span>
            <h2 class="section-title">What's <em>Baking?</em></h2>
            <p class="section-subtitle">Browse our full range and add your favourites to your cart. Then send us an enquiry and we'll be in touch!</p>
        </div>

        <!-- Category Filter Tabs -->
        <div class="category-tabs reveal" role="tablist" aria-label="Filter products by category">
            <button class="cat-tab active" data-cat="all" role="tab" aria-selected="true">🌟 All</button>
            <button class="cat-tab" data-cat="bouquets" role="tab" aria-selected="false">💐 Bouquets</button>
            <button class="cat-tab" data-cat="cupcakes" role="tab" aria-selected="false">🧁 Cupcakes</button>
            <button class="cat-tab" data-cat="cakes" role="tab" aria-selected="false">🎂 Mini Cakes</button>
            <button class="cat-tab" data-cat="brownies" role="tab" aria-selected="false">🍫 Brownies</button>
            <button class="cat-tab" data-cat="cookies" role="tab" aria-selected="false">🍪 Cookies</button>
            <button class="cat-tab" data-cat="treats" role="tab" aria-selected="false">🎁 Treat Boxes</button>
        </div>

        <!-- Products Grid — populated by JS -->
        <div class="products-grid" id="productsGrid" role="list" aria-label="Products">
            <!-- Products rendered by site.js -->
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════
     FILLINGS SECTION
════════════════════════════════════════════ -->
<section class="section fillings-section" id="fillings" aria-label="Optional fillings">
    <div class="section-inner">
        <div class="section-header reveal">
            <span class="section-eyebrow">Extras</span>
            <h2 class="section-title">Optional <em>Fillings</em></h2>
            <p class="section-subtitle">Elevate your cupcakes and bouquets with a luscious filling. Add-ons are priced per 12 cupcakes.</p>
        </div>

        <div class="fillings-grid">
            <div class="filling-chip reveal reveal-delay-1">
                <span class="filling-name">🍮 Caramel</span>
                <span class="filling-price">+R20 / 12</span>
            </div>
            <div class="filling-chip reveal reveal-delay-1">
                <span class="filling-name">🍫 Chocolate</span>
                <span class="filling-price">+R20 / 12</span>
            </div>
            <div class="filling-chip reveal reveal-delay-2">
                <span class="filling-name">🍦 Vanilla Cream</span>
                <span class="filling-price">+R20 / 12</span>
            </div>
            <div class="filling-chip reveal reveal-delay-2">
                <span class="filling-name">🍓 Strawberry</span>
                <span class="filling-price">+R25 / 12</span>
            </div>
            <div class="filling-chip reveal reveal-delay-3">
                <span class="filling-name">🍪 Oreo</span>
                <span class="filling-price">+R30 / 12</span>
            </div>
            <div class="filling-chip reveal reveal-delay-3">
                <span class="filling-name">🌰 Nutella</span>
                <span class="filling-price">+R35 / 12</span>
            </div>
            <div class="filling-chip reveal reveal-delay-4">
                <span class="filling-name">🍫 Bar One</span>
                <span class="filling-price">+R35 / 12</span>
            </div>
        </div>

        <p class="section-subtitle reveal" style="margin-top:2rem; font-size:0.85rem; color:var(--text-muted);">
            💬 Please mention your preferred fillings in the comments when you send your enquiry.
        </p>
    </div>
</section>

<!-- ═══════════════════════════════════════════
     CUSTOM ORDERS BANNER
════════════════════════════════════════════ -->
<section class="section" id="custom" style="background:var(--pink-50); padding-top:40px; padding-bottom:80px;">
    <div class="section-inner">
        <div class="custom-banner reveal">
            <h2>🎨 Custom Orders Welcome</h2>
            <p>
                Have a specific theme, colour palette, or message in mind? We love bringing unique visions to life!
                Colours, themes, characters, messages and more — all available. Priced accordingly.
            </p>
            <a href="#" class="btn btn-white" onclick="openEnquiryModal(); return false;">
                💌 Get a Custom Quote
            </a>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════
     ORDER NOTES SECTION
════════════════════════════════════════════ -->
<section class="section" style="background:white; padding:60px 2rem;">
    <div class="section-inner">
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:1.5rem; max-width:900px; margin:0 auto;">
            <div class="feature-card reveal" style="text-align:left; padding:1.5rem;">
                <span style="font-size:1.8rem; display:block; margin-bottom:0.6rem;">📅</span>
                <strong style="font-size:0.95rem; color:var(--text-dark); display:block; margin-bottom:0.3rem;">2 Days' Notice</strong>
                <span style="font-size:0.84rem; color:var(--text-light);">Orders require at least 2 days' notice to ensure freshness.</span>
            </div>
            <div class="feature-card reveal reveal-delay-1" style="text-align:left; padding:1.5rem;">
                <span style="font-size:1.8rem; display:block; margin-bottom:0.6rem;">💳</span>
                <strong style="font-size:0.95rem; color:var(--text-dark); display:block; margin-bottom:0.3rem;">50% Deposit</strong>
                <span style="font-size:0.84rem; color:var(--text-light);">A 50% deposit is required to confirm and secure your order.</span>
            </div>
            <div class="feature-card reveal reveal-delay-2" style="text-align:left; padding:1.5rem;">
                <span style="font-size:1.8rem; display:block; margin-bottom:0.6rem;">🎨</span>
                <strong style="font-size:0.95rem; color:var(--text-dark); display:block; margin-bottom:0.3rem;">Price Variations</strong>
                <span style="font-size:0.84rem; color:var(--text-light);">Prices may vary for custom designs and special requests.</span>
            </div>
            <div class="feature-card reveal reveal-delay-3" style="text-align:left; padding:1.5rem;">
                <span style="font-size:1.8rem; display:block; margin-bottom:0.6rem;">⚡</span>
                <strong style="font-size:0.95rem; color:var(--text-dark); display:block; margin-bottom:0.3rem;">Limited Slots</strong>
                <span style="font-size:0.84rem; color:var(--text-light);">We have limited slots available — book early to avoid disappointment!</span>
            </div>
        </div>
    </div>
</section>
