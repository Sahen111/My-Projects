<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bitter Bites — Handcrafted cupcakes, cakes, brownies and treats baked with love." />
    <title>@ViewData["Title"] — Bitter Bites Bakery</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Dancing+Script:wght@600;700&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Main Stylesheet -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ── Sprinkle Particles Canvas ── -->
    <canvas class="sprinkles-canvas" id="sprinklesCanvas" aria-hidden="true"></canvas>

    <!-- ═══════════════════════════════
         NAVBAR
    ═══════════════════════════════ -->
    <nav class="navbar" id="mainNav" role="navigation" aria-label="Main navigation">
        <a href="/" class="nav-brand" aria-label="Bitter Bites Home">
            <span class="brand-name">Bitter Bites</span>
            <span class="brand-dot" aria-hidden="true"></span>
        </a>

        <ul class="nav-links" role="list">
            <li><a href="#products">Menu</a></li>
            <li><a href="#fillings">Fillings</a></li>
            <li><a href="#custom">Custom Orders</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>

        <button class="nav-cart-btn" id="navCartBtn" aria-label="Open shopping cart" aria-haspopup="true">
            🛒 Cart
            <span class="cart-badge" aria-live="polite" aria-label="Items in cart">0</span>
        </button>
    </nav>

    <!-- ═══════════════════════════════
         MAIN CONTENT
    ═══════════════════════════════ -->
    <main>
        @RenderBody()
    </main>

    <!-- ═══════════════════════════════
         CART SIDEBAR
    ═══════════════════════════════ -->
    <div class="cart-overlay" id="cartOverlay" aria-hidden="true"></div>

    <aside class="cart-sidebar" id="cartSidebar" role="dialog" aria-modal="true" aria-label="Shopping cart">
        <div class="cart-header">
            <h2 class="cart-title">🛍️ Your Order</h2>
            <button class="cart-close" id="cartCloseBtn" aria-label="Close cart">✕</button>
        </div>

        <div class="cart-items" id="cartItems" role="list" aria-label="Cart items">
            <!-- Items populated by JS -->
        </div>

        <div class="cart-empty" id="cartEmpty" role="status">
            <span class="cart-empty-icon">🧁</span>
            <h3>Your cart is empty</h3>
            <p>Browse our delicious menu and add something sweet!</p>
        </div>

        <div class="cart-footer">
            <div class="cart-total-row">
                <span class="cart-total-label">Estimated Total</span>
                <span class="cart-total-amount" id="cartTotal">R0</span>
            </div>
            <button class="cart-enquire-btn" id="cartEnquireBtn" disabled aria-label="Proceed to enquiry">
                💌 Send Enquiry
            </button>
            <p style="font-size:0.75rem; color:var(--text-muted); text-align:center; margin-top:0.75rem; line-height:1.5;">
                50% deposit required to confirm. Prices may vary for custom designs. Orders require 2 days' notice.
            </p>
        </div>
    </aside>

    <!-- ═══════════════════════════════
         ENQUIRY MODAL
    ═══════════════════════════════ -->
    <div class="modal-overlay" id="enquiryModal" role="dialog" aria-modal="true" aria-labelledby="modalHeading">
        <div class="modal-box">
            <button class="modal-close-btn" id="modalCloseBtn" aria-label="Close enquiry form">✕</button>

            <!-- Form Wrapper -->
            <div class="enquiry-form-wrap">
                <div class="modal-header">
                    <span class="modal-icon" aria-hidden="true">💌</span>
                    <h2 class="modal-title" id="modalHeading">Send an Enquiry</h2>
                    <p class="modal-subtitle">We'll get back to you within 24 hours!</p>
                </div>

                <!-- Cart Summary -->
                <div class="modal-cart-summary">
                    <h4>🧁 Your Selected Items</h4>
                    <div id="modalCartItems">
                        <!-- Populated by JS -->
                    </div>
                    <div style="display:flex; justify-content:space-between; margin-top:0.75rem; padding-top:0.6rem; border-top:1.5px solid var(--pink-200);">
                        <span style="font-weight:700; font-size:0.88rem; color:var(--text-dark);">Estimated Total</span>
                        <span style="font-weight:700; color:var(--pink-600);" id="modalTotal">R0</span>
                    </div>
                </div>

                <!-- Enquiry Form -->
                <form id="enquiryForm" novalidate>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" for="enquiryName">Your Name *</label>
                            <input type="text" class="form-input" id="enquiryName" placeholder="e.g. Sarah Smith" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="enquiryPhone">Phone Number *</label>
                            <input type="tel" class="form-input" id="enquiryPhone" placeholder="e.g. 082 000 0000" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="enquiryComments">Comments / Special Requests</label>
                        <textarea class="form-textarea" id="enquiryComments" placeholder="Tell us about flavours, colours, dates, allergies, or anything else you'd like us to know…"></textarea>
                    </div>

                    <button type="submit" class="form-submit-btn">
                        💌 Send My Enquiry
                    </button>
                    <p class="form-note">
                        Your enquiry will be sent to us via email. Limited slots available — book early!
                    </p>
                </form>
            </div>

            <!-- Success State -->
            <div class="success-state" role="status" aria-live="polite">
                <span class="success-icon" aria-hidden="true">🎉</span>
                <h2 class="success-title">Enquiry Sent!</h2>
                <p class="success-text">
                    Thank you! Your email client has opened with your order details.<br>
                    We'll be in touch within 24 hours. Can't wait to bake for you!
                </p>
                <button class="btn btn-primary" id="modalSuccessClose" style="margin-top:1.5rem;">Close</button>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════
         FOOTER
    ═══════════════════════════════ -->
    <footer class="footer" id="contact">
        <div class="footer-inner">
            <!-- Brand -->
            <div>
                <div class="footer-brand-name">Bitter Bites</div>
                <p class="footer-tagline">
                    Handcrafted sweet treats baked with love in every bite. Cupcakes, cakes, brownies and more — made to order, just for you.
                </p>
                <div class="footer-social">
                    <a href="#" class="social-btn" aria-label="Instagram">📷</a>
                    <a href="#" class="social-btn" aria-label="Facebook">📘</a>
                    <a href="#" class="social-btn" aria-label="WhatsApp">💬</a>
                    <a href="mailto:ramble.comp@gmail.com" class="social-btn" aria-label="Email us">📧</a>
                </div>
            </div>

            <!-- Quick Links -->
            <div>
                <h4>Menu</h4>
                <ul class="footer-links">
                    <li><a href="#products" onclick="document.querySelector('[data-cat=bouquets]')?.click()">Cupcake Bouquets</a></li>
                    <li><a href="#products" onclick="document.querySelector('[data-cat=cupcakes]')?.click()">Classic Cupcakes</a></li>
                    <li><a href="#products" onclick="document.querySelector('[data-cat=cakes]')?.click()">Mini Cakes</a></li>
                    <li><a href="#products" onclick="document.querySelector('[data-cat=brownies]')?.click()">Brownies</a></li>
                    <li><a href="#products" onclick="document.querySelector('[data-cat=cookies]')?.click()">Cookies</a></li>
                    <li><a href="#products" onclick="document.querySelector('[data-cat=treats]')?.click()">Treat Boxes</a></li>
                </ul>
            </div>

            <!-- Info -->
            <div>
                <h4>Info</h4>
                <ul class="footer-links">
                    <li><a href="#fillings">Flavours & Fillings</a></li>
                    <li><a href="#custom">Custom Orders</a></li>
                    <li><a href="#products">Pricing</a></li>
                    <li><a href="#contact">Contact Us</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div>
                <h4>Get In Touch</h4>
                <div class="footer-contact-item">
                    <span class="footer-contact-icon">📞</span>
                    <span>081 476 4284</span>
                </div>
                <div class="footer-contact-item">
                    <span class="footer-contact-icon">📧</span>
                    <a href="mailto:ramble.comp@gmail.com" style="color:var(--pink-300);">ramble.comp@gmail.com</a>
                </div>
                <div class="footer-contact-item">
                    <span class="footer-contact-icon">💬</span>
                    <span>DM or WhatsApp to order</span>
                </div>
                <div class="footer-contact-item">
                    <span class="footer-contact-icon">⏰</span>
                    <span>Orders require 2 days' notice. 50% deposit to confirm.</span>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <span>© @DateTime.Now.Year Bitter Bites. All rights reserved.</span>
            <span>Made with ❤️ and lots of sugar</span>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
